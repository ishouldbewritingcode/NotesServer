{
	"info": {
		"name": "NotesServer GraphQL API",
		"_postman_id": "b31c25ec-1d30-4c2b-8f3d-2b6e9f5bc9c2",
		"description": "Postman collection for testing the NotesServer GraphQL API.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5300",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Get User By Email",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"query\": \"query GetUserByEmail($email: String!) { userByEmail(email: $email) { id name email } }\",\n  \"operationName\": \"GetUserByEmail\",\n  \"variables\": { \"email\": \"test@example.com\" }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/graphql",
					"host": ["{{baseUrl}}"],
					"path": ["graphql"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"const jsonData = pm.response.json();",
							"pm.test('No GraphQL errors', function () {",
							"    pm.expect(jsonData.errors).to.be.undefined;",
							"});",
							"pm.test('User object returned', function () {",
							"    pm.expect(jsonData.data).to.have.property('userByEmail');",
							"    pm.expect(jsonData.data.userByEmail).to.be.an('object');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "Get User By ID",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"query\": \"query GetUser($id: ID!) { user(id: $id) { id name email } }\",\n  \"operationName\": \"GetUser\",\n  \"variables\": { \"id\": \"00000000-0000-0000-0000-000000000000\" }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/graphql",
					"host": ["{{baseUrl}}"],
					"path": ["graphql"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"const jsonData = pm.response.json();",
							"pm.test('No GraphQL errors', function () {",
							"    pm.expect(jsonData.errors).to.be.undefined;",
							"});",
							"pm.test('User data shape is valid', function () {",
							"    pm.expect(jsonData.data).to.have.property('user');",
							"    if (jsonData.data.user) {",
							"        pm.expect(jsonData.data.user).to.have.property('id');",
							"        pm.expect(jsonData.data.user).to.have.property('email');",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "Get Notes By User ID",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"query\": \"query GetUserNotes($userId: ID!) { notesByUser(userId: $userId) { id text userId } }\",\n  \"operationName\": \"GetUserNotes\",\n  \"variables\": { \"userId\": \"00000000-0000-0000-0000-000000000000\" }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/graphql",
					"host": ["{{baseUrl}}"],
					"path": ["graphql"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"const jsonData = pm.response.json();",
							"pm.test('No GraphQL errors', function () {",
							"    pm.expect(jsonData.errors).to.be.undefined;",
							"});",
							"pm.test('Notes array returned', function () {",
							"    pm.expect(jsonData.data).to.have.property('notesByUser');",
							"    pm.expect(jsonData.data.notesByUser).to.be.an('array');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "Get All Notes",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"query\": \"{ notes { id text userId } }\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/graphql",
					"host": ["{{baseUrl}}"],
					"path": ["graphql"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"const jsonData = pm.response.json();",
							"pm.test('No GraphQL errors', function () {",
							"    pm.expect(jsonData.errors).to.be.undefined;",
							"});",
							"pm.test('Notes list returned', function () {",
							"    pm.expect(jsonData.data).to.have.property('notes');",
							"    pm.expect(jsonData.data.notes).to.be.an('array');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		}
	]
}
